# =============================================================================
# SECRETS — never commit real credentials
# =============================================================================
# The live config (with real API keys) is always ignored.
# Commit only config.example.yaml (placeholder values).
config.yaml

# =============================================================================
# Runtime output
# =============================================================================
# Raw JSON snapshots contain your real post data — ignore by default.
# To share a specific snapshot, use: git add -f data/weekly/2025-W22.json
data/weekly/*.json

# Persistent analytics store — contains your full history, gitignored.
data/analytics.xlsx

# Reports contain your content analytics — ignore by default.
reports/

# LinkedIn exports may contain personally identifiable information.
linkedin_drops/*.csv
linkedin_drops/*.xlsx

# Substack exports (may contain subscriber data)
substack_drops/*.csv

# O'Reilly payment emails (contain financial/personal data)
oreilly_drops/*.eml
oreilly_drops/*.rtf

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/
.env
pip-wheel-metadata/
*.so

# =============================================================================
# Environment / tooling
# =============================================================================
.env
.env.*
*.env

# Claude Code local settings (machine-specific)
.claude/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Logs
logs/
*.log

# =============================================================================
# Dashboard (viz/)
# =============================================================================
# Dashboard.jsx is the reference template committed to the repo.
# Claude produces a self-contained artifact in claude.ai — no local build needed.
viz/node_modules/
viz/dist/
